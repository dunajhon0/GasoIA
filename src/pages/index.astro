---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PriceCard from '../components/PriceCard';
import CookieBanner from '../components/CookieBanner';

export const prerender = false;
---

<Layout
  title="GasoIA – Precios de carburantes en España"
  description="Precio oficial de la gasolina y el gasóleo en España. Datos del Ministerio actualizados cada día. Buscador de gasolineras, histórico y calculadora."
>
  <Navbar slot="navbar" />

  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-24 -left-24 w-96 h-96 rounded-full blur-3xl opacity-20" style="background:radial-gradient(circle, #10b981, transparent)"></div>
      <div class="absolute -top-24 right-0 w-96 h-96 rounded-full blur-3xl opacity-15" style="background:radial-gradient(circle, #6366f1, transparent)"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-12 pb-8">
      <!-- Header -->
      <div class="text-center mb-10 animate-fade-in">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-5"
          style="background:rgba(42,165,255,0.12);color:#2aa5ff;border:1px solid rgba(42,165,255,0.25)">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse inline-block"></span>
          Datos oficiales · Actualización automática diaria
        </div>
        <h1 class="text-4xl sm:text-5xl font-extrabold mb-3 leading-tight">
          Precios de carburantes
          <span class="gradient-text block sm:inline"> en España hoy</span>
        </h1>
        <p class="text-lg text-muted max-w-xl mx-auto">
          Fuente oficial del Ministerio de Industria. Sin intermediarios, sin scraping.
        </p>
      </div>

      <!-- Price cards (loaded client-side) -->
      <div id="price-cards" class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6 max-w-2xl mx-auto">
        <div class="card p-5 sm:p-6">
          <div class="skeleton h-5 w-24 mb-3"></div>
          <div class="skeleton h-9 w-32 mb-2"></div>
          <div class="skeleton h-4 w-20"></div>
        </div>
        <div class="card p-5 sm:p-6">
          <div class="skeleton h-5 w-24 mb-3"></div>
          <div class="skeleton h-9 w-32 mb-2"></div>
          <div class="skeleton h-4 w-20"></div>
        </div>
      </div>

      <!-- Last updated + disclaimer -->
      <p id="last-updated" class="text-center text-xs text-muted mb-10">Cargando datos…</p>

      <!-- Quick links -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 max-w-2xl mx-auto animate-slide-up">
        {[
          { href: '/gasolineras', icon: '📍', label: 'Gasolineras cercanas' },
          { href: '/calculadora', icon: '🧮', label: 'Calcular viaje' },
          { href: '/historico',   icon: '📈', label: 'Ver histórico' },
          { href: '/combustibles',icon: '⛽', label: 'Todos los combustibles' },
        ].map(item => (
          <a href={item.href} class="card p-4 text-center hover:border-brand-400 transition-colors group">
            <span class="text-2xl block mb-1 group-hover:scale-110 transition-transform" aria-hidden="true">{item.icon}</span>
            <span class="text-xs font-medium text-muted group-hover:text-brand-500">{item.label}</span>
          </a>
        ))}
      </div>

      <!-- Nearest Station CTA -->
      <div class="max-w-2xl mx-auto mt-6 animate-slide-up" style="animation-delay: 150ms">
        <a 
          href="/gasolineras?nearby=1" 
          class="block relative overflow-hidden rounded-3xl p-6 sm:p-8 bg-slate-900 text-white shadow-2xl hover:scale-[1.02] active:scale-[0.98] transition-all group"
        >
          <!-- Decoration -->
          <div class="absolute top-0 right-0 -mr-12 -mt-12 w-48 h-48 bg-brand-500/20 rounded-full blur-3xl pointer-events-none"></div>
          <div class="absolute bottom-0 left-0 -ml-8 -mb-8 w-32 h-32 bg-indigo-500/10 rounded-full blur-2xl pointer-events-none"></div>
          
          <div class="relative flex flex-col sm:flex-row items-center gap-6 text-center sm:text-left">
            <div class="w-16 h-16 sm:w-20 sm:h-20 shrink-0 bg-white/10 rounded-2xl flex items-center justify-center text-4xl shadow-inner border border-white/10 group-hover:bg-brand-500/20 group-hover:border-brand-500/30 transition-colors">
              📍
            </div>
            
            <div class="flex-1">
              <h3 class="text-2xl sm:text-3xl font-black mb-2 tracking-tight">
                Gasolinera <span class="text-brand-400">más cercana</span>
              </h3>
              <p class="text-slate-400 text-sm sm:text-base font-medium leading-relaxed">
                Activa tu ubicación y encontraremos al instante la estación de servicio más próxima a ti.
              </p>
            </div>
            
            <div class="bg-white text-slate-900 h-12 w-12 sm:h-14 sm:w-14 rounded-full flex items-center justify-center text-xl shadow-lg border-4 border-slate-900 group-hover:bg-brand-400 transition-colors">
              →
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Top Cities preview -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 section">
    <h2 class="section-title">Precios por ciudad <a href="/ciudades" class="text-sm font-normal text-brand-500 ml-2">Ver todas →</a></h2>
    <p class="section-subtitle">Precio medio hoy de Gasolina 95 en las principales ciudades</p>
    <div id="cities-preview" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      {Array(10).fill(null).map(() => (
        <div class="card p-4 flex flex-col gap-3">
          <div class="flex items-start justify-between">
            <div class="skeleton h-5 w-24"></div>
            <div class="skeleton h-4 w-8"></div>
          </div>
          <div class="skeleton h-3 w-16 mb-2"></div>
          <div class="space-y-2">
            <div class="flex justify-between"><div class="skeleton h-3 w-16"></div><div class="skeleton h-3 w-12"></div></div>
            <div class="flex justify-between"><div class="skeleton h-3 w-16"></div><div class="skeleton h-3 w-12"></div></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Mini-sparkline section for brands -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 pb-12">
    <h2 class="section-title">Acceso rápido <a href="/marcas" class="text-sm font-normal text-brand-500 ml-2">Ver marcas →</a></h2>
    <div class="flex flex-wrap gap-2">
      {['Repsol','Cepsa','BP','Shell','Alcampo','Petroprix','Plenoil','Galp'].map(brand => (
        <a
          href={`/gasolineras?brand=${brand}`}
          class="badge bg-gray-100 dark:bg-white/5 text-gray-700 dark:text-gray-300 hover:bg-brand-500/10 hover:text-brand-500 transition-colors px-3 py-1.5 rounded-full text-sm font-medium"
        >
          {brand}
        </a>
      ))}
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<!-- Cookie Banner -->
<CookieBanner client:load />

<script>
async function loadDashboard() {
  try {
    const [summaryRes, citiesRes] = await Promise.all([
      fetch(`/api/summary?t=${Date.now()}`),
      fetch(`/api/cities/top10?t=${Date.now()}`),
    ]);
    const summary = summaryRes.ok ? await summaryRes.json() : null;
    const cities  = citiesRes.ok  ? await citiesRes.json() : null;

    // ── Price cards ──────────────────────────────────────────────────────────
    const cardsEl = document.getElementById('price-cards');
    if (cardsEl && summary) {
      const sp95 = summary.sp95;
      const diesel = summary.dieselA;

      const fmtPrice = (p: number | null) => p != null ? p.toFixed(3) : '—';
      const fmtDelta = (d: number | null, pct: number | null) => {
        if (d == null) return '';
        const sign = d > 0 ? '+' : '';
        return `${sign}${d.toFixed(4)} € (${sign}${(pct ?? 0).toFixed(2)}%)`;
      };
      
      const spark = (pts: number[], baseColor: string, id: string) => {
        if (!pts || pts.length === 0) return '';
        
        const w = 140, h = 60, padding = 8;
        const availableH = h - (padding * 2);
        const min = Math.min(...pts), max = Math.max(...pts);
        const range = (max - min) || 0.0001;
        
        console.log(`[Dashboard] Sparkline ${id}: ${pts.length} pts`, pts);

        // Handle 1 point case or all points equal
        const isSinglePoint = pts.length === 1;
        const allPointsEqual = max === min;
        
        // Trend-based coloring
        const first = pts[0], last = pts[pts.length - 1];
        const isUp = !isSinglePoint && last > first;
        const isDown = !isSinglePoint && last < first;
        const color = isUp ? '#ef4444' : (isDown ? '#22c55e' : baseColor);
        
        // Generate smooth curve points
        const points = pts.map((p, i) => {
          const x = isSinglePoint ? w / 2 : (i / (pts.length - 1)) * w;
          const y = (isSinglePoint || allPointsEqual) 
            ? h / 2 
            : h - padding - ((p - min) / range) * availableH;
          return { x, y };
        });

        // Path (Bezier or Line)
        let d = '';
        if (isSinglePoint) {
            d = `M 0,${h/2} L ${w},${h/2}`;
        } else {
            d = `M ${points[0].x},${points[0].y}`;
            for (let i = 0; i < points.length - 1; i++) {
              const cx = (points[i].x + points[i+1].x) / 2;
              const cy = (points[i].y + points[i+1].y) / 2;
              d += ` Q ${points[i].x},${points[i].y} ${cx},${cy}`;
            }
            d += ` L ${points[points.length-1].x},${points[points.length-1].y}`;
        }

        // Fill down to bottom
        const fillD = isSinglePoint ? '' : `${d} V ${h} H 0 Z`;

        return `
          <div class="relative w-[100px] sm:w-[140px] h-[40px] sm:h-[50px] shrink-0 pointer-events-none" style="filter: drop-shadow(0 4px 6px ${color}20)">
            <svg viewBox="0 0 ${w} ${h}" class="w-full h-full block overflow-visible" preserveAspectRatio="none">
              <defs>
                <linearGradient id="grad-${id}" x1="0%" y1="0%" x2="0%" y2="100%">
                  <stop offset="0%" style="stop-color:${color};stop-opacity:0.2" />
                  <stop offset="100%" style="stop-color:${color};stop-opacity:0" />
                </linearGradient>
              </defs>
              ${fillD ? `<path d="${fillD}" fill="url(#grad-${id})" />` : ''}
              <path d="${d}" fill="none" stroke="${color}" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
        `;
      };

      const sp95Color = '#6366f1', dieselColor = '#f59e0b';
      
      const renderCard = (title: string, icon: string, fuelData: any, color: string, id: string) => `
        <div class="card p-5 sm:p-6 flex flex-col gap-4 relative overflow-hidden group hover:border-brand-500 transition-all duration-300">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xl sm:text-2xl">${icon}</span>
            <span class="font-bold text-[10px] sm:text-[11px] text-muted uppercase tracking-widest">${title}</span>
          </div>
          
          <div class="flex items-end justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline gap-1">
                <p class="text-3xl sm:text-4xl font-black font-mono leading-none tracking-tighter text-slate-900 dark:text-white">${fmtPrice(fuelData?.today)}</p>
                <span class="text-xs font-bold text-muted uppercase tracking-tighter">€/L</span>
              </div>
              
              <div class="mt-3 space-y-1.5 font-bold">
                <p class="text-[10px] text-muted uppercase tracking-tight">Cruce ayer: <span class="text-slate-800 dark:text-slate-200">${fmtPrice(fuelData?.yesterday)} €</span></p>
                ${fuelData?.delta != null ? `
                  <div class="flex items-center gap-1.5 text-[11px] uppercase tracking-tighter ${fuelData.delta > 0 ? 'text-red-500' : fuelData.delta < 0 ? 'text-green-500' : 'text-slate-400'}">
                    <span class="text-xs">${fuelData.delta > 0 ? '▲' : fuelData.delta < 0 ? '▼' : '▬'}</span>
                    <span>${fmtDelta(fuelData.delta, fuelData.deltaPct)}</span>
                  </div>
                ` : ''}
              </div>
              <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 mt-2">${fuelData?.count ? fuelData.count.toLocaleString('es-ES') + ' gasolineras' : ''}</p>
            </div>
            
            <div class="flex items-center self-center min-w-[100px] sm:min-w-[140px] justify-end">
              ${spark(fuelData?.sparkline, color, id)}
            </div>
          </div>
        </div>
      `;

      cardsEl.innerHTML = `
        ${renderCard('Gasolina 95 (SP95)', '⛽', sp95, sp95Color, 'sp95')}
        ${renderCard('Gasóleo A (Diesel)', '🚛', diesel, dieselColor, 'diesel')}
      `;
    }

    // ── Last updated ────────────────────────────────────────────────────────
    const updEl = document.getElementById('last-updated');
    if (updEl && summary) {
      const d = new Date(summary.updatedAt);
      updEl.textContent = `Última actualización: ${d.toLocaleString('es-ES')} · Datos oficiales del Ministerio de Industria`;
    }

    // ── Cities preview ──────────────────────────────────────────────────────
    const citiesEl = document.getElementById('cities-preview');
    if (citiesEl && cities?.cities) {
      citiesEl.innerHTML = cities.cities.map((c: any) => `
        <a href="/gasolineras?city=${encodeURIComponent(c.city)}" class="card p-4 flex flex-col justify-between hover:border-brand-400 transition-colors animate-fade-in group">
          <div>
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-bold text-base leading-tight group-hover:text-brand-500 transition-colors">${c.city}</h3>
              <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-slate-100 dark:bg-slate-800 text-muted uppercase tracking-tighter">${c.stationCount} ⛽</span>
            </div>
            <p class="text-[10px] text-muted font-medium mb-3 uppercase tracking-wider">📍 ${c.province}</p>
          </div>
          
          <div class="space-y-2 mb-4">
            <div class="flex items-center justify-between text-xs">
              <span class="text-muted font-medium">Gasolina 95</span>
              <span class="font-mono font-bold text-indigo-600 dark:text-indigo-400">${c.sp95 != null ? c.sp95.toFixed(3) + '€' : '—'}</span>
            </div>
            <div class="flex items-center justify-between text-xs">
              <span class="text-muted font-medium">Gasóleo A</span>
              <span class="font-mono font-bold text-amber-600 dark:text-amber-400">${c.dieselA != null ? c.dieselA.toFixed(3) + '€' : '—'}</span>
            </div>
          </div>

          <div class="text-[11px] font-bold text-brand-500 flex items-center gap-1 group-hover:gap-2 transition-all">
            Ver estaciones <span>→</span>
          </div>
        </a>
      `).join('');
    }
  } catch (e) {
    console.error('Dashboard load error:', e);
  }
}

loadDashboard();
</script>
