{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@worker/*": [
                "./worker/*"
            ]
        },
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "strict": true,
        "noUncheckedIndexedAccess": false,
        "skipLibCheck": true
    },
    "include": [
        "src",
        "worker",
        "tests",
        "*.mjs",
        "*.cjs"
    ]
}