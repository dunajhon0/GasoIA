---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import StationFinder from '../components/StationFinder';

export const prerender = false;
const cityParam = Astro.url.searchParams.get('city');
const cityName = cityParam ? (cityParam.charAt(0).toUpperCase() + cityParam.slice(1).toLowerCase()) : '';

const title = cityName 
  ? `Gasolineras en ${cityName} hoy | Precio gasolina – GasoIA`
  : "Buscador de gasolineras baratas cerca de mí – GasoIA";

const description = cityName
  ? `Consulta las gasolineras más baratas en ${cityName} hoy. Precios actualizados de gasolina 95 y gasóleo A en tiempo real.`
  : "Encuentra las gasolineras más baratas cerca de tu ubicación o en cualquier ciudad de España. Precios actualizados hoy. Filtra por combustible y marca.";
---

<Layout
  title={title}
  description={description}
>
  <Navbar slot="navbar" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 section animate-fade-in">
    <h1 class="section-title">Buscador de gasolineras 📍</h1>
    <p class="section-subtitle">
      Encuentra la gasolinera más barata cerca de ti o en cualquier ciudad de España.
    </p>

    <StationFinder client:load />
  </div>

  <Footer slot="footer" />
</Layout>
