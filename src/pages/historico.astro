---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import HistoryChart from '../components/HistoryChart';

export const prerender = false;
---

<Layout
  title="Histórico de precios de carburantes – GasoIA"
  description="Gráfico del histórico de precios de Gasolina 95 y Gasóleo A en España. Últimos 30, 90, 180 o 365 días. Datos oficiales del Ministerio."
>
  <Navbar slot="navbar" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 section animate-fade-in">
    <h1 class="section-title">Histórico de precios ⚡</h1>
    <p class="section-subtitle">Tendencia de precios medios nacionales. Datos oficiales del Ministerio.</p>

    <HistoryChart client:only="react" />

    <!-- Explanation -->
    <div class="card-flat p-5 mt-6 text-sm text-muted leading-relaxed">
      <h2 class="font-semibold text-base text-current mb-2">¿Cómo se calcula este precio?</h2>
      <p>
        Se toma la media aritmética del precio de venta al público (PVP) de todas las gasolineras de España continental y Baleares,
        excluyendo Canarias, Ceuta y Melilla (que tienen fiscalidad especial). Los datos proceden del registro oficial del
        <strong>Ministerio de Industria, Turismo y Comercio</strong> y se actualizan automáticamente cada día.
      </p>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>
