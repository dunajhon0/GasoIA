    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@types/leaflet": "^1.9.12",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^9.9.0",
    "eslint-plugin-astro": "^1.2.4",
