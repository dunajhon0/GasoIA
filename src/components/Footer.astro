---
---
<footer class="mt-16 border-t border-color surface" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-3">
          <img src="/logo.png" alt="GasoIA Icon" class="h-8 w-8 object-contain" width="32" height="32" />
          <span class="font-[700] text-xl tracking-[0.3px] text-slate-900 dark:text-white">Gaso<span class="text-brand-500">IA</span></span>
        </a>
        <p class="text-sm text-muted leading-relaxed">
          Precios oficiales de carburantes en España. Datos del Ministerio de Industria, actualizados diariamente.
        </p>
      </div>

      <!-- Herramientas -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-muted mb-3">Herramientas</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/calculadora" class="hover:text-brand-500 transition-colors">Calculadora de viaje</a></li>
          <li><a href="/gasolineras" class="hover:text-brand-500 transition-colors">Buscador de gasolineras</a></li>
          <li><a href="/comparador"  class="hover:text-brand-500 transition-colors">Comparador de ciudades</a></li>
          <li><a href="/favoritos"   class="hover:text-brand-500 transition-colors">Mis favoritos</a></li>
        </ul>
      </div>

      <!-- Datos -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-muted mb-3">Datos</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/historico"    class="hover:text-brand-500 transition-colors">Histórico de precios</a></li>
          <li><a href="/ciudades"     class="hover:text-brand-500 transition-colors">Precios por ciudad</a></li>
          <li><a href="/combustibles" class="hover:text-brand-500 transition-colors">Todos los combustibles</a></li>
          <li><a href="/marcas"       class="hover:text-brand-500 transition-colors">Ranking de marcas</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-muted mb-3">Legal</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/legal/privacidad" class="hover:text-brand-500 transition-colors">Privacidad</a></li>
          <li><a href="/legal/cookies"    class="hover:text-brand-500 transition-colors">Política de cookies</a></li>
          <li><a href="/legal/terminos"   class="hover:text-brand-500 transition-colors">Términos de uso</a></li>
          <li><a href="/contacto"         class="hover:text-brand-500 transition-colors">Contacto</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-color pt-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-muted">
      <p>
        © {new Date().getFullYear()} GasoIA. Datos oficiales del
        <a
          href="https://www.minetur.gob.es/"
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:text-brand-500"
        >
          Ministerio de Industria, Turismo y Comercio
        </a>.
      </p>
      <p class="flex items-center gap-1.5">
        <span class="inline-block w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
        Actualización automática diaria
      </p>
    </div>
  </div>
</footer>
