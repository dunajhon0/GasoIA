---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import StationFinder from '../components/StationFinder';

export const prerender = false;
---

<Layout
  title="Buscador de gasolineras baratas cerca de mí – GasoIA"
  description="Encuentra las gasolineras más baratas cerca de tu ubicación o en cualquier ciudad de España. Precios actualizados hoy. Filtra por combustible y marca."
>
  <Navbar slot="navbar" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 section animate-fade-in">
    <h1 class="section-title">Buscador de gasolineras 📍</h1>
    <p class="section-subtitle">
      Encuentra la gasolinera más barata cerca de ti o en cualquier ciudad de España.
    </p>

    <StationFinder client:load />
  </div>

  <Footer slot="footer" />
</Layout>
